rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {matricula}
    // Fields:
    //   - matricula: string (required)
    //   - nome: string (required)
    //   - senha: string (required, hashed)
    //   - dataRegistro: string (required, ISO 8601)
    //   - deviceId: string (optional)
    //   - token: string (optional)
    //   - role: string (optional, 'admin' | 'user')
    //
    // Collection: bannedDevices
    // Document ID: {deviceId}
    // Fields:
    //   - deviceId: string (required)
    //   - dataBanimento: string (required, ISO 8601)
    //   - motivo: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isNatulab() {
      return isAuthenticated() && request.auth.token.email.endsWith('@natulab.com.br');
    }

    function isAdmin() {
      return isNatulab() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "guilhermesatos455@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['matricula', 'nome', 'uid', 'dataRegistro']) &&
             data.matricula is string && data.matricula.size() > 0 &&
             data.nome is string && data.nome.size() > 0 &&
             data.uid == request.auth.uid &&
             data.dataRegistro is string;
    }

    function isValidBannedDevice(data) {
      return data.keys().hasAll(['deviceId', 'dataBanimento']) &&
             data.deviceId is string && data.deviceId.size() > 0 &&
             data.dataBanimento is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow get: if isAuthenticated();
      allow list: if isAdmin();
      allow create: if isNatulab() && isValidUser(request.resource.data) && isOwner(uid);
      allow update: if isNatulab() && isValidUser(request.resource.data) && (isOwner(uid) || isAdmin());
      allow delete: if isAdmin();
    }

    match /ai_logs/{logId} {
      allow create: if isNatulab();
      allow read, delete: if isAdmin();
    }

    match /bannedDevices/{deviceId} {
      allow read: if true;
      allow write: if isAdmin() && isValidBannedDevice(request.resource.data);
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
